function buildCard(s){
  const blocks=s.blocks.map(b=>`
    <div class="block ${b.nuance?'block-nuance':''}">
      <div class="block-label">${b.label} <span class="timing">${b.timing}</span></div>
      <div class="script-text">${b.text}</div>
      ${b.note?`<div class="en-note">${b.note}</div>`:''}
      ${b.wc?`<div class="wc">${b.wc}</div>`:''}
    </div>`).join('');
  return`<div class="script-card">
    <div class="card-header ${s.headerClass}">
      <div class="card-title ${s.titleClass}">${s.header}</div>
      <span class="stance-badge ${s.badgeClass}">${s.badge}</span>
    </div>${blocks}</div>`;}

document.getElementById('bothGrid').innerHTML=buildCard(scriptA)+buildCard(scriptB);
document.getElementById('posAGrid').innerHTML=buildCard(scriptA);
document.getElementById('posBGrid').innerHTML=buildCard(scriptB);

function showTab(id,btn){
  document.querySelectorAll('.content').forEach(c=>c.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');}
</script>
